@page
@model ChangePasswordModel
@{
}

<body>
	<form method="post">
		<h2>Change Password</h2>
		<div>
			<div>
				<label>Current Password</label>
				<input asp-for="currentPassword" type="password" placeholder="Enter current password" />
				<span asp-validation-for="students.studentPassword" class="text-danger"></span>
			</div>

			<div>
				<label>New Password</label>
				<input asp-for="newPassword" type="password" placeholder="Enter new password" />
				<span asp-validation-for="newPassword" class="text-danger"></span>
			</div>

			<div>
				<label>Confirm Password</label>
				<input asp-for="confirmPassword" type="password" placeholder="Enter new password" />
				<span asp-validation-for="confirmPassword" class="text-danger"></span>
			</div>
		</div>

		@if (!string.IsNullOrEmpty(Model.ErrorMessage))
		{
			<div class="text-danger">@Model.ErrorMessage</div>
		}

		<button type="submit">Save</button>
		<button type="button" onclick="window.location.href='/StudentDashboard'">Cancel</button>
	</form>
</body>
